{
  "name": "ai-app-backend",
  "version": "1.0.0",
  "description": "AI application backend with LangGraph.js and Express",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec tsx src/server.ts",
    "agent": "tsx src/agent.ts",
    "build": "tsc",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@langchain/core": "^1.2.2",
    "@langchain/groq": "^1.3.1",
    "@langchain/langgraph": "^1.4.7",
    "@tavily/core": "^0.7.6",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
